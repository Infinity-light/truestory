# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get from: https://cloud.walletconnect.com → Create Project
NEXT_PUBLIC_WC_PROJECT_ID=<your-wc-project-id>

# ── Smart Contract (filled after T4.4 — forge deploy to Monad Testnet) ────────
NEXT_PUBLIC_TRISIGN_CONTRACT_ADDRESS=

# ── Alibaba Cloud DashScope STT (filled at T2.1) ─────────────────────────────
# Get from: https://dashscope.aliyun.com → API Keys
# Required model: Qwen3-ASR-Flash-Realtime
DASHSCOPE_API_KEY=
